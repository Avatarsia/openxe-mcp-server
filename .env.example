# OpenXE MCP Server - Konfiguration
# Kopiere diese Datei zu .env und passe die Werte an.

# Pflicht
OPENXE_URL=http://192.168.0.100
OPENXE_USERNAME=api-user
OPENXE_PASSWORD=mein-passwort

# Optional
# OPENXE_MODE=router          # router (Standard, 2 Tools) | full (alle 69 Tools) | readonly (nur Lesen)
# OPENXE_TIMEOUT=30000        # Request-Timeout in ms
# OPENXE_ALLOW_HTTP=1         # HTTP-Warnung unterdruecken (LAN-Betrieb)
# OPENXE_AUDIT_LOG=1          # Audit-Log aller Tool-Aufrufe
# OPENXE_API_PATH=/api/index.php
